<nav class="bg-white shadow mb-6">
  <div class="max-w-5xl mx-auto px-8">
    <div class="flex items-center h-14 gap-8">
      <%= link_to 'Climbing Gym Model', model_home_index_path, class: 'text-lg font-bold text-indigo-600 hover:text-indigo-800 mr-4' %>

      <% if defined?(@simulation) && @simulation&.persisted? %>
        <div class="flex gap-6 text-sm">
          <%= link_to @simulation.name, model_simulation_path(@simulation), class: 'text-gray-600 hover:text-gray-900 font-medium' %>
          <%= link_to 'Climbers', model_simulation_climbers_path(@simulation), class: "#{request.path.include?('/climbers') ? 'text-indigo-600 font-medium' : 'text-gray-600 hover:text-gray-900'}" %>
          <%= link_to 'Balance', model_simulation_balance_index_path(@simulation), class: "#{request.path.include?('/balance') || request.path.include?('/days') ? 'text-indigo-600 font-medium' : 'text-gray-600 hover:text-gray-900'}" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
