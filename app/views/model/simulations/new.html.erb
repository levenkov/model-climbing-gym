<%= render 'model/shared/navigation' %>
<div class="max-w-3xl mx-auto p-8">
  <h1 class="text-2xl font-bold mb-6">New simulation</h1>

  <%= form_with model: @simulation, url: simulations_path, class: 'space-y-6' do |f| %>
    <div class="bg-white rounded-lg shadow p-6">
      <div>
        <%= f.label :name, class: 'block text-sm font-medium text-gray-700' %>
        <%= f.text_field :name, value: "Simulation #{Time.current.strftime('%Y-%m-%d %H:%M')}", class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Climber generation</h2>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :climber_count, 'Number of climbers', class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :climber_count, value: 100, min: 1, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div></div>
        <div>
          <%= f.label :visits_per_week_mean, 'Visits/week mean', class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :visits_per_week_mean, value: 3.0, step: 0.1, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :visits_per_week_std, 'Visits/week std', class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :visits_per_week_std, value: 1.5, step: 0.1, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :flexible_schedule_ratio, 'Flexible schedule ratio', class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :flexible_schedule_ratio, value: 0.4, step: 0.05, min: 0, max: 1, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :own_shoes_ratio, 'Own shoes ratio', class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :own_shoes_ratio, value: 0.3, step: 0.05, min: 0, max: 1, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Simulation</h2>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :days, 'Days to simulate', class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :days, value: 90, min: 1, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :start_date, class: 'block text-sm font-medium text-gray-700' %>
          <%= f.date_field :start_date, value: '2026-01-01', class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :initial_balance, class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :initial_balance, value: 500000, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Pricing</h2>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :visit_fee, class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :visit_fee, value: 500, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :shoe_rental_fee, class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :shoe_rental_fee, value: 200, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Monthly expenses</h2>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :rent, class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :rent, value: 300000, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :electricity, class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :electricity, value: 30000, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :water, class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :water, value: 10000, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :other_bills, class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :other_bills, value: 15000, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
        <div>
          <%= f.label :staff_salaries, class: 'block text-sm font-medium text-gray-700' %>
          <%= f.number_field :staff_salaries, value: 200000, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border' %>
        </div>
      </div>
    </div>

    <div class="flex gap-4">
      <%= f.submit 'Create simulation', class: 'bg-indigo-600 text-white rounded-md py-2 px-6 text-sm font-medium hover:bg-indigo-700 cursor-pointer' %>
      <%= link_to 'Cancel', root_path, class: 'py-2 px-4 text-sm text-gray-600 hover:text-gray-800' %>
    </div>
  <% end %>
</div>
