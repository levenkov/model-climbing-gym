<%= render 'model/shared/navigation' %>
<div class="max-w-5xl mx-auto p-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @simulation.name %></h1>
      <p class="text-sm text-gray-500">Created <%= @simulation.created_at.strftime('%b %d, %Y %H:%M') %></p>
    </div>
    <%= link_to 'Delete', simulation_path(@simulation), data: { turbo_method: :delete, turbo_confirm: 'Delete this simulation and all its data?' }, class: 'text-sm text-red-500 hover:text-red-700' %>
  </div>

  <% if flash[:notice] %>
    <div class="mb-4 p-4 text-sm text-green-700 bg-green-100 rounded-lg border border-green-200"><%= flash[:notice] %></div>
  <% end %>

  <% if @simulation.generating_climbers? || @simulation.simulating? %>
    <!-- Progress bar -->
    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-2">
        <span id="statusText"><%= @simulation.status.humanize %></span>
      </h2>
      <div class="flex justify-between text-sm text-gray-600 mb-1">
        <span id="progressText"><%= @simulation.progress_current %> / <%= @simulation.progress_total %></span>
        <span id="progressPercent"><%= @simulation.progress_total > 0 ? (@simulation.progress_current * 100 / @simulation.progress_total) : 0 %>%</span>
      </div>
      <div class="w-full bg-gray-200 rounded-full h-2">
        <div id="progressBar" class="bg-indigo-600 h-2 rounded-full transition-all duration-300"
             style="width: <%= @simulation.progress_total > 0 ? (@simulation.progress_current * 100 / @simulation.progress_total) : 0 %>%"></div>
      </div>
    </div>

    <script>
      document.addEventListener('turbo:load', function() {
        const interval = setInterval(function() {
          fetch('<%= progress_simulation_path(@simulation) %>')
            .then(r => r.json())
            .then(data => {
              const pct = data.total > 0 ? Math.round(data.current / data.total * 100) : 0;
              document.getElementById('statusText').textContent = data.status.replace(/_/g, ' ');
              document.getElementById('progressText').textContent = data.current + ' / ' + data.total;
              document.getElementById('progressPercent').textContent = pct + '%';
              document.getElementById('progressBar').style.width = pct + '%';

              if (data.status !== 'generating_climbers' && data.status !== 'simulating') {
                clearInterval(interval);
                location.reload();
              }
            });
        }, 500);
      });
    </script>
  <% else %>
    <!-- Step 1: Generate climbers -->
    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-semibold">Step 1: Climbers</h2>
          <% if @climber_count > 0 %>
            <p class="text-sm text-gray-500 mt-1"><%= @climber_count %> climbers generated</p>
          <% else %>
            <p class="text-sm text-gray-500 mt-1">No climbers yet</p>
          <% end %>
        </div>
        <div class="flex gap-3">
          <% if @climber_count > 0 %>
            <%= link_to 'View', simulation_climbers_path(@simulation), class: 'bg-gray-100 text-gray-700 rounded-md py-2 px-4 text-sm font-medium hover:bg-gray-200' %>
          <% end %>
          <% if @simulation.pending? || @simulation.failed? %>
            <%= link_to 'Generate climbers', generate_climbers_simulation_path(@simulation), data: { turbo_method: :post }, class: 'bg-indigo-600 text-white rounded-md py-2 px-4 text-sm font-medium hover:bg-indigo-700' %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Step 2: Run simulation -->
    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-semibold">Step 2: Simulation</h2>
          <% if @simulation_days > 0 %>
            <p class="text-sm text-gray-500 mt-1"><%= @simulation_days %> days, <%= @visit_count %> visits, <%= @transaction_count %> transactions</p>
          <% elsif @climber_count > 0 %>
            <p class="text-sm text-gray-500 mt-1">Ready to simulate</p>
          <% else %>
            <p class="text-sm text-gray-500 mt-1">Generate climbers first</p>
          <% end %>
        </div>
        <div class="flex gap-3">
          <% if @simulation_days > 0 %>
            <%= link_to 'View balance', simulation_balance_index_path(@simulation), class: 'bg-gray-100 text-gray-700 rounded-md py-2 px-4 text-sm font-medium hover:bg-gray-200' %>
            <%= link_to 'Reset simulation', reset_simulation_simulation_path(@simulation), data: { turbo_method: :delete, turbo_confirm: 'Reset simulation data? Climbers will be preserved.' }, class: 'text-sm text-red-500 hover:text-red-700 py-2 px-4' %>
          <% end %>
          <% if @simulation.climbers_ready? || @simulation.failed? %>
            <%= link_to 'Run simulation', run_simulation_simulation_path(@simulation), data: { turbo_method: :post }, class: 'bg-indigo-600 text-white rounded-md py-2 px-4 text-sm font-medium hover:bg-indigo-700' %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Results -->
    <% if @simulation.completed? %>
      <div class="grid grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-lg shadow p-6 text-center">
          <div class="text-3xl font-bold text-indigo-600"><%= @climber_count %></div>
          <div class="text-gray-500 mt-1">Climbers</div>
        </div>
        <div class="bg-white rounded-lg shadow p-6 text-center">
          <div class="text-3xl font-bold text-indigo-600"><%= @simulation_days %></div>
          <div class="text-gray-500 mt-1">Days</div>
        </div>
        <div class="bg-white rounded-lg shadow p-6 text-center">
          <div class="text-3xl font-bold text-indigo-600"><%= @visit_count %></div>
          <div class="text-gray-500 mt-1">Visits</div>
        </div>
        <div class="bg-white rounded-lg shadow p-6 text-center">
          <div class="text-3xl font-bold text-indigo-600"><%= @transaction_count %></div>
          <div class="text-gray-500 mt-1">Transactions</div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
