<div class="max-w-5xl mx-auto p-8">
  <div class="flex items-center gap-4 mb-6">
    <a href="<%= model_balance_index_path %>" class="text-indigo-600 hover:text-indigo-800">&larr; Back to balance</a>
    <h1 class="text-2xl font-bold"><%= @date.strftime('%B %d, %Y') %></h1>
  </div>

  <!-- Summary cards -->
  <div class="grid grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="text-3xl font-bold text-indigo-600"><%= @total_visits %></div>
      <div class="text-gray-500 mt-1">Total visits</div>
    </div>
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="text-3xl font-bold text-indigo-600"><%= @peak_visitors %></div>
      <div class="text-gray-500 mt-1">Peak visitors (<%= @peak_hour %>:00)</div>
    </div>
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="text-3xl font-bold text-green-600"><%= number_with_delimiter(@total_income.to_i) %></div>
      <div class="text-gray-500 mt-1">Income</div>
    </div>
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="text-3xl font-bold text-red-600"><%= number_with_delimiter(@total_expenses.to_i) %></div>
      <div class="text-gray-500 mt-1">Expenses</div>
    </div>
  </div>

  <!-- Hourly presence chart -->
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-semibold mb-4">Visitors throughout the day</h2>
    <canvas id="hourlyChart" height="80"></canvas>
  </div>

  <!-- Revenue breakdown -->
  <div class="grid grid-cols-2 gap-4 mb-6">
    <% if @income_by_category.any? %>
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold mb-3">Income breakdown</h3>
        <table class="w-full text-sm">
          <% @income_by_category.sort_by { |_, v| -v }.each do |category, amount| %>
            <tr class="border-b">
              <td class="py-2"><%= category.humanize %></td>
              <td class="py-2 text-right font-mono text-green-600"><%= number_with_delimiter(amount.to_i) %></td>
            </tr>
          <% end %>
        </table>
      </div>
    <% end %>
    <% if @expenses_by_category.any? %>
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold mb-3">Expenses breakdown</h3>
        <table class="w-full text-sm">
          <% @expenses_by_category.sort_by { |_, v| -v }.each do |category, amount| %>
            <tr class="border-b">
              <td class="py-2"><%= category.humanize %></td>
              <td class="py-2 text-right font-mono text-red-600"><%= number_with_delimiter(amount.to_i) %></td>
            </tr>
          <% end %>
        </table>
      </div>
    <% end %>
  </div>

  <!-- Visit log -->
  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-lg font-semibold mb-3">Visit log</h2>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b text-left text-gray-500">
          <th class="py-2">Visitor</th>
          <th class="py-2">Check in</th>
          <th class="py-2">Check out</th>
          <th class="py-2">Duration</th>
        </tr>
      </thead>
      <tbody>
        <% @visits.order(:checked_in_at).each do |visit| %>
          <tr class="border-b">
            <td class="py-2"><%= visit.user.name %></td>
            <td class="py-2 font-mono"><%= visit.checked_in_at.strftime('%H:%M') %></td>
            <td class="py-2 font-mono"><%= visit.checked_out_at&.strftime('%H:%M') || '—' %></td>
            <td class="py-2 font-mono">
              <% if visit.checked_out_at %>
                <%= ((visit.checked_out_at - visit.checked_in_at) / 1.hour).round(1) %>h
              <% else %>
                —
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const hours = <%= raw @hourly_presence.map(&:first).to_json %>;
      const counts = <%= raw @hourly_presence.map(&:last).to_json %>;

      new Chart(document.getElementById('hourlyChart').getContext('2d'), {
        type: 'bar',
        data: {
          labels: hours.map(h => h + ':00'),
          datasets: [{
            label: 'Visitors present',
            data: counts,
            backgroundColor: 'rgba(79, 70, 229, 0.6)',
            borderColor: 'rgb(79, 70, 229)',
            borderWidth: 1
          }]
        },
        options: {
          scales: {
            x: { title: { display: true, text: 'Hour' } },
            y: { title: { display: true, text: 'Visitors' }, beginAtZero: true }
          },
          plugins: { legend: { display: false } }
        }
      });
    });
  </script>
</div>
