<%= render 'model/shared/navigation' %>
<div class="max-w-5xl mx-auto p-8">
  <h1 class="text-2xl font-bold mb-6">Generator</h1>

  <% if flash[:notice] %>
    <div class="mb-4 p-4 text-sm text-green-700 bg-green-100 rounded-lg border border-green-200"><%= flash[:notice] %></div>
  <% end %>

  <div class="grid grid-cols-2 gap-6 mb-6">
    <!-- Climber generation form -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-1">Generate climbers</h2>
      <p class="text-sm text-gray-500 mb-4">Current: <%= @climber_count %> climbers</p>

      <form id="climberForm" class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700">Count</label>
          <input type="number" name="climber[count]" value="100" min="1" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700">Visits/week mean</label>
            <input type="number" name="climber[visits_per_week_mean]" value="3.0" step="0.1" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Visits/week std</label>
            <input type="number" name="climber[visits_per_week_std]" value="1.5" step="0.1" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700">Flexible schedule ratio</label>
            <input type="number" name="climber[flexible_schedule_ratio]" value="0.4" step="0.05" min="0" max="1" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Own shoes ratio</label>
            <input type="number" name="climber[own_shoes_ratio]" value="0.3" step="0.05" min="0" max="1" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
          </div>
        </div>

        <button type="submit" id="climberBtn" class="w-full bg-indigo-600 text-white rounded-md py-2 px-4 text-sm font-medium hover:bg-indigo-700">
          Generate climbers
        </button>
      </form>

      <div id="climberProgress" class="mt-4 hidden">
        <div class="flex justify-between text-sm text-gray-600 mb-1">
          <span id="climberProgressText">0 / 0</span>
          <span id="climberProgressPercent">0%</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div id="climberProgressBar" class="bg-indigo-600 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>
    </div>

    <!-- Simulation form -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-1">Run simulation</h2>
      <p class="text-sm text-gray-500 mb-4">Current: <%= @simulation_days %> days simulated</p>

      <form id="simulationForm" class="space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700">Days</label>
            <input type="number" name="simulation[days]" value="90" min="1" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Start date</label>
            <input type="date" name="simulation[start_date]" value="2026-01-01" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Initial balance</label>
          <input type="number" name="simulation[initial_balance]" value="500000" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
        </div>

        <div class="border-t pt-3 mt-3">
          <p class="text-sm font-medium text-gray-700 mb-2">Pricing</p>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm text-gray-500">Visit fee</label>
              <input type="number" name="simulation[visit_fee]" value="500" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
            </div>
            <div>
              <label class="block text-sm text-gray-500">Shoe rental fee</label>
              <input type="number" name="simulation[shoe_rental_fee]" value="200" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
            </div>
          </div>
        </div>

        <div class="border-t pt-3 mt-3">
          <p class="text-sm font-medium text-gray-700 mb-2">Monthly expenses</p>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm text-gray-500">Rent</label>
              <input type="number" name="simulation[rent]" value="300000" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
            </div>
            <div>
              <label class="block text-sm text-gray-500">Electricity</label>
              <input type="number" name="simulation[electricity]" value="30000" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
            </div>
            <div>
              <label class="block text-sm text-gray-500">Water</label>
              <input type="number" name="simulation[water]" value="10000" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
            </div>
            <div>
              <label class="block text-sm text-gray-500">Other bills</label>
              <input type="number" name="simulation[other_bills]" value="15000" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
            </div>
            <div>
              <label class="block text-sm text-gray-500">Staff salaries</label>
              <input type="number" name="simulation[staff_salaries]" value="200000" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm p-2 border">
            </div>
          </div>
        </div>

        <button type="submit" id="simulationBtn" class="w-full bg-indigo-600 text-white rounded-md py-2 px-4 text-sm font-medium hover:bg-indigo-700">
          Run simulation
        </button>
      </form>

      <div id="simulationProgress" class="mt-4 hidden">
        <div class="flex justify-between text-sm text-gray-600 mb-1">
          <span id="simulationProgressText">0 / 0</span>
          <span id="simulationProgressPercent">0%</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div id="simulationProgressBar" class="bg-indigo-600 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Reset -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <h3 class="text-lg font-semibold">Reset all data</h3>
        <p class="text-sm text-gray-500">Delete all generated climbers, visits, transactions, and gym states.</p>
      </div>
      <%= link_to 'Reset', reset_model_generator_index_path, data: { turbo_method: :delete, turbo_confirm: 'Are you sure? This will delete all generated data.' }, class: 'bg-red-600 text-white rounded-md py-2 px-4 text-sm font-medium hover:bg-red-700' %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

  function formToJson(form) {
    const data = {};
    new FormData(form).forEach((value, key) => {
      const match = key.match(/^(\w+)\[(\w+)\]$/);
      if (match) {
        data[match[1]] = data[match[1]] || {};
        data[match[1]][match[2]] = value;
      }
    });
    return data;
  }

  function pollProgress(jobName, elements) {
    const interval = setInterval(function() {
      fetch('/model/generator/progress?job=' + jobName)
        .then(r => r.json())
        .then(data => {
          const pct = data.total > 0 ? Math.round(data.completed / data.total * 100) : 0;
          elements.text.textContent = data.completed + ' / ' + data.total;
          elements.percent.textContent = pct + '%';
          elements.bar.style.width = pct + '%';

          if (data.status === 'completed') {
            clearInterval(interval);
            elements.bar.classList.remove('bg-indigo-600');
            elements.bar.classList.add('bg-green-500');
            elements.btn.disabled = false;
            elements.btn.textContent = elements.originalText;
            setTimeout(() => location.reload(), 1000);
          }
        });
    }, 500);
  }

  // Climber form
  const climberForm = document.getElementById('climberForm');
  const climberBtn = document.getElementById('climberBtn');
  climberForm.addEventListener('submit', function(e) {
    e.preventDefault();
    climberBtn.disabled = true;
    climberBtn.textContent = 'Generating...';
    document.getElementById('climberProgress').classList.remove('hidden');

    fetch('/model/generator/generate_climbers', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify(formToJson(climberForm))
    });

    pollProgress('climbers', {
      text: document.getElementById('climberProgressText'),
      percent: document.getElementById('climberProgressPercent'),
      bar: document.getElementById('climberProgressBar'),
      btn: climberBtn,
      originalText: 'Generate climbers'
    });
  });

  // Simulation form
  const simForm = document.getElementById('simulationForm');
  const simBtn = document.getElementById('simulationBtn');
  simForm.addEventListener('submit', function(e) {
    e.preventDefault();
    simBtn.disabled = true;
    simBtn.textContent = 'Running...';
    document.getElementById('simulationProgress').classList.remove('hidden');

    fetch('/model/generator/generate_simulation', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify(formToJson(simForm))
    });

    pollProgress('simulation', {
      text: document.getElementById('simulationProgressText'),
      percent: document.getElementById('simulationProgressPercent'),
      bar: document.getElementById('simulationProgressBar'),
      btn: simBtn,
      originalText: 'Run simulation'
    });
  });
});
</script>
